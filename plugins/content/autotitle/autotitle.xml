<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="content" method="upgrade">
	<name>plg_content_autotitle</name>
	<author>Joomla! Project</author>
	<creationDate>2026-03</creationDate>
	<copyright>(C) 2026 Open Source Matters, Inc.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail>admin@joomla.org</authorEmail>
	<authorUrl>www.joomla.org</authorUrl>
	<version>1.0.0</version>
	<description>PLG_CONTENT_AUTOTITLE_XML_DESCRIPTION</description>
	<namespace path="src">Joomla\Plugin\Content\Autotitle</namespace>
	<files>
		<folder plugin="autotitle">services</folder>
		<folder>src</folder>
	</files>
	<languages>
		<language tag="en-GB">language/en-GB/plg_content_autotitle.ini</language>
		<language tag="en-GB">language/en-GB/plg_content_autotitle.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="autotitle_text"
					type="text"
					label="PLG_CONTENT_AUTOTITLE_FIELD_TEXT_LABEL"
					description="PLG_CONTENT_AUTOTITLE_FIELD_TEXT_DESC"
					default="Draft article"
					filter="string"
				/>
			</fieldset>
		</fields>
	</config>
</extension>
